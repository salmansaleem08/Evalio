# ─── Frontend (Vercel) — prefix public vars with NEXT_PUBLIC_ ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_secret_key
SUPABASE_PROJECT_ID=your_project_id

# Pilot / early access
PILOT_ACCESS_KEY=your_pilot_access_key
PILOT_ALLOWED_EMAILS=email1@example.com,email2@example.com

# ─── Backend (Render) ───
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# Gemini (add your key)
GEMINI_API_KEY=

# File upload limits
MAX_STUDENT_SHEETS=5
MAX_UPLOAD_SIZE_MB=25

# School inquiries (waitlist) emailed to you
CONTACT_NOTIFY_EMAIL=msalmansaleem08@gmail.com
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=Evalio <onboarding@resend.dev>

# Run Supabase migration: supabase/migrations/001_grading_sessions.sql
